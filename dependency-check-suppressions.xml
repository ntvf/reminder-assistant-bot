<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        FALSE POSITIVES — Telegram Java bot library (telegrambots-meta 9.3.0)
        OWASP CPE matching hits cpe:2.3:a:telegram:telegram:9.3.0 based on the version number,
        but these CVEs describe vulnerabilities in the Telegram desktop/mobile application,
        not the Java bot API library. No code path from this library is affected.
    -->
    <suppress>
        <notes>False positive: CVE-2019-10044 affects Telegram desktop client, not the Java bot library.</notes>
        <packageUrl regex="true">^pkg:maven/org\.telegram/.*$</packageUrl>
        <cve>CVE-2019-10044</cve>
    </suppress>
    <suppress>
        <notes>False positive: CVE-2024-7014 affects Telegram desktop client, not the Java bot library.</notes>
        <packageUrl regex="true">^pkg:maven/org\.telegram/.*$</packageUrl>
        <cve>CVE-2024-7014</cve>
    </suppress>

